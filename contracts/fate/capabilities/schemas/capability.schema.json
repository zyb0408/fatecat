{
  "schemaVersion": 1,
  "requiredTopLevel": ["schemaVersion", "capabilities"],
  "requiredCapabilityFields": [
    "capabilityId",
    "name",
    "tradition",
    "status",
    "defaultVisibility",
    "inputRequired",
    "inputOptional",
    "engine",
    "report",
    "evidence",
    "riskPolicy"
  ],
  "allowedStatus": ["planned", "experimental", "production"],
  "allowedVisibility": ["default", "optional", "standalone", "hidden"],
  "allowedRiskLevel": ["folk_reference", "entertainment", "requires_disclaimer"],
  "invariants": [
    "defaultVisibility=default 必须且只能用于 bazi",
    "planned / experimental 能力不得由 executor 生产执行",
    "所有能力必须声明 evidence 与 riskPolicy",
    "新增能力不得混入综合八字默认 Markdown"
  ]
}
