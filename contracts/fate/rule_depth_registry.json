        "tenGods"
      ],
      "conditions": [
        "月令、人元司令、通根、透干、藏干、五行分数齐备"
      ],
      "conflictPolicy": "强弱结论必须允许中和、偏强、偏弱等灰度标签；不得由单一五行分数硬断。",
      "riskBoundary": "只作八字结构证据，不输出确定性人生结论。",
      "sourceRuleIds": [
        "bazi.month_command_priority",
        "bazi.day_master_strength",
        "bazi.renyuan_siling_weight",
        "bazi.strength_score_golden"
      ]
    },
    {
      "id": "bazi.depth.pattern.establishment",
      "system": "bazi",
      "layer": "core",
      "topic": "格局成败",
      "priority": 95,
      "weight": 0.86,
      "evidenceFields": [
        "geju",
        "baziBenchmark.patternRegistry",
        "baziBenchmark.ganzhiPriority"
      ],
      "conditions": [
        "月令可定",
        "透干、藏干和合冲关系可追溯"
      ],
      "conflictPolicy": "无法确认成格时输出候选格局和缺失条件，不把候选写成定格。",
      "riskBoundary": "格局只影响解释优先级，不替代完整命例判断。",
      "sourceRuleIds": [
        "bazi.pattern_by_month_command",
        "bazi.pattern_root_transparency",
        "bazi.ganzhi_priority"
      ]
    },
    {
      "id": "bazi.depth.yongshen.strategy_matrix",
      "system": "bazi",
      "layer": "core",
      "topic": "用神策略",
      "priority": 92,
      "weight": 0.84,
      "evidenceFields": [
        "yongShen",
        "baziBenchmark.yongShenStrategies",
        "climateScores",
        "wuxingScores"
      ],
      "conditions": [
        "调候、扶抑、通关、病药至少有一类可解释依据"
      ],
      "conflictPolicy": "调候、扶抑、格局用神冲突时保留多策略，不用单一结论覆盖全部。",
      "riskBoundary": "用神输出为传统文化分析，不承诺现实结果。",
      "sourceRuleIds": [
        "bazi.regulating_climate",
        "bazi.balance_five_elements",
        "bazi.yongshen_strategy"
      ],
      "strategyScoringMatrix": [
        {
          "strategy": "调候",
          "appliesWhen": [
            "月令、节气、寒暖燥湿、调候原始依据存在"
          ],
          "doesNotApplyWhen": [
            "缺少季节气候依据",
            "把调候当作医疗/养生处方"
          ],
          "scoreBasis": [
            "yongShen.basis",
            "yongShen.tiaohouRaw",
            "climateScores"
          ],
          "conflictPolicy": "调候优先解释气候偏性，但不得覆盖扶抑、通关、病药。"
        },
        {
          "strategy": "扶抑",
          "appliesWhen": [
            "日主强弱、月令、通根、透干、五行分数齐备"
          ],
          "doesNotApplyWhen": [
            "只存在单一强弱标签",
            "五行分数或藏干缺失"
          ],
          "scoreBasis": [
            "dayMaster.strength",
            "wuxingScores.strongScore",
            "wuxingScores.statusDetail"
          ],
          "conflictPolicy": "扶抑与调候冲突时并列呈现，不能单独覆盖用神。"
        },
        {
          "strategy": "通关",
          "appliesWhen": [
            "干支冲合刑害破或五行克战关系显著",
            "存在可缓冲的中介五行"
          ],
          "doesNotApplyWhen": [
            "关系链不可追溯",
            "只有单点五行偏枯而无冲突链"
          ],
          "scoreBasis": [
            "ganzhiRelations",
            "branchRelations",
            "baziBenchmark.ganzhiPriority"
          ],
          "conflictPolicy": "通关只解释冲突缓冲，不替代调候或扶抑主策略。"
        },
        {
          "strategy": "病药",
          "appliesWhen": [
            "五行偏枯、寒暖燥湿或格局病处可定位",
            "存在对应药处证据"
          ],
          "doesNotApplyWhen": [
            "偏枯不明显",
            "病处无法回指证据字段",
            "输出生活处方"
          ],
          "scoreBasis": [
            "wuxingScores.fiveElementScore",
            "climateScores",
            "geju"
          ],
          "conflictPolicy": "病药作为解释优先级，不输出现实诊疗、金融或法律决策。"
        }
      ]
    },
    {
      "id": "bazi.depth.relation.collision_priority",
      "system": "bazi",
      "layer": "core",
      "topic": "干支关系",
      "priority": 88,
      "weight": 0.78,
      "evidenceFields": [
        "ganzhiRelations",
        "branchRelations",
        "baziBenchmark.ganzhiPriority"
      ],
      "conditions": [
        "天干、地支、藏干关系可展开"
      ],
      "conflictPolicy": "合冲刑害破按优先级展示；合化是否成化必须另列依据，缺依据则只登记合象。",
      "riskBoundary": "关系触发只作结构变化证据。",
      "sourceRuleIds": [
        "bazi.stem_branch_relations",
        "bazi.ganzhi_priority"
      ]
    },
    {
      "id": "bazi.depth.fortune.trigger_chain",
      "system": "bazi",
      "layer": "dynamic",
      "topic": "岁运触发",
      "priority": 80,
      "weight": 0.72,
      "evidenceFields": [
        "majorFortune",
        "annualFortune",
        "monthlyFortune",
        "baziBenchmark.fortuneTriggers"
      ],
      "conditions": [
        "大运、流年、流月至少一层可用"
      ],
      "conflictPolicy": "动态触发不得覆盖原局结构；只说明何处被引动。",
      "riskBoundary": "不得输出确定事件、恐吓表述或高风险决策建议。",
      "sourceRuleIds": [
        "bazi.fortune_trigger_boundary",
        "bazi.fortune_start_boundary"
      ],
      "triggerMatrix": [
        {
          "type": "major_stage",
          "label": "大运阶段",
          "evidenceFields": [
            "majorFortune.pillars",
            "jiaoYun"
          ],
          "appliesWhen": [
            "大运字段可用",
            "当前年龄落入某一步大运或至少可列出大运序列"
          ],
          "doesNotApplyWhen": [
            "未完成起运计算",
            "大运字段为空"
          ],
          "riskBoundary": "大运只定阶段背景，不直接断事件。"
        },
        {
          "type": "annual_trigger",
          "label": "流年触发",
          "evidenceFields": [
            "annualFortune",
            "baziBenchmark.fortuneTriggers"
          ],
          "appliesWhen": [
            "流年干支可与原局或大运比较"
          ],
          "doesNotApplyWhen": [
            "流年字段为空",
            "无法回指触发对象"
          ],
          "riskBoundary": "流年只说明结构被引动，不承诺结果。"
        },
        {
          "type": "monthly_refinement",
          "label": "流月细化",
          "evidenceFields": [
            "monthlyFortune",
            "baziBenchmark.fortuneTriggers"
          ],
          "appliesWhen": [
            "流月字段可用",
            "存在大运或流年背景"
          ],
          "doesNotApplyWhen": [
            "只有流月而缺少原局/大运/流年上下文"
          ],
          "riskBoundary": "流月只能细化窗口，不反向覆盖大运流年。"
        },
        {
          "type": "fu_yin",
          "label": "伏吟",
          "evidenceFields": [
            "fourPillars",
            "annualFortune",
            "majorFortune"
          ],
          "appliesWhen": [
            "动态干支与原局或大运干支相同"
          ],
          "doesNotApplyWhen": [
            "只存在地支同气但干支不完全相同"
          ],
          "riskBoundary": "伏吟只作重复引动证据，不作灾断。"
        },
        {
          "type": "fan_yin",
          "label": "反吟",
          "evidenceFields": [
            "fourPillars",
            "annualFortune",
            "branchClash",
            "stemControl"
          ],
          "appliesWhen": [
            "动态干支与原局形成天克地冲或强反向关系"
          ],
          "doesNotApplyWhen": [
            "只存在单一冲或单一克且无层级证据"
          ],
          "riskBoundary": "反吟只提示结构冲突增强，不输出确定事件。"
        },
        {
          "type": "sui_yun_bing_lin",
          "label": "岁运并临",
          "evidenceFields": [
            "majorFortune",
            "annualFortune"
          ],
          "appliesWhen": [
            "流年干支与当前大运干支相同"
          ],
          "doesNotApplyWhen": [
            "当前大运不可定位",
            "只存在同支或同干"
          ],
          "riskBoundary": "岁运并临只作层级重叠证据。"
        },
        {
          "type": "tian_ke_di_chong",
          "label": "天克地冲",
          "evidenceFields": [
            "fourPillars",
            "annualFortune",
            "stemControl",
            "branchClash"
          ],
          "appliesWhen": [
            "天干相克且地支相冲"
          ],
          "doesNotApplyWhen": [
            "只有天克或只有地冲"
          ],
          "riskBoundary": "天克地冲不得包装成恐吓式断语。"
        }
      ]
    },
    {
      "id": "bazi.depth.auxiliary.boundary_guard",
      "system": "bazi",
      "layer": "boundary",
      "topic": "辅助体系边界",
      "priority": 60,
