      ]
    },
    {
      "id": "ziwei.depth.mutagen.scope_chain",
      "system": "ziwei",
      "layer": "dynamic",
      "topic": "四化层级",
      "priority": 92,
      "weight": 0.83,
      "evidenceFields": [
        "ziweiMutagenFlow",
        "ziweiHoroscope"
      ],
      "conditions": [
        "生年、大限、流年、流月、流日或流时四化至少一层可用"
      ],
      "conflictPolicy": "本命四化与运限四化必须分层，不得混读。",
      "riskBoundary": "四化引动只作趋势证据，不输出确定事件。",
      "sourceRuleIds": [
        "ziwei.mutagen_scope",
        "ziwei.mutagen_flow",
        "ziwei.mutagen_opposition"
      ]
    },
    {
      "id": "ziwei.depth.pattern.condition_matrix",
      "system": "ziwei",
      "layer": "core",
      "topic": "紫微格局",
      "priority": 85,
      "weight": 0.74,
      "evidenceFields": [
        "ziweiPatternMatches",
        "ziweiStarEncyclopedia"
      ],
      "conditions": [
        "主星集合、宫位与缺失条件可列出"
      ],
      "conflictPolicy": "格局未满足时输出 missingStars，不把候选格局写成成立。",
      "riskBoundary": "格局解释必须保留不成立原因。",
      "sourceRuleIds": [
        "ziwei.pattern_match_seed",
        "ziwei.star_encyclopedia_seed"
      ]
    },
    {
      "id": "ziwei.depth.palace.topic_matrix",
      "system": "ziwei",
      "layer": "topic",
      "topic": "十二宫专题",
      "priority": 78,
      "weight": 0.68,
      "evidenceFields": [
        "ziweiPalaceTopics",
        "palaceAnalysis"
      ],
      "conditions": [
        "十二宫数量完整"
      ],
      "conflictPolicy": "专题解释必须回到宫位、星曜、四化和限运，不输出孤立断语。",
      "riskBoundary": "健康、财富、婚恋等主题不得替代专业建议。",
      "sourceRuleIds": [
        "ziwei.palace_topic"
      ]
    },
    {
      "id": "ziwei.depth.fortune.linkage_chain",
      "system": "ziwei",
      "layer": "dynamic",
      "topic": "运限联动",
      "priority": 75,
      "weight": 0.66,
      "evidenceFields": [
        "ziweiInterpretation.fortuneLinks",
        "ziweiHoroscope"
      ],
      "conditions": [
        "本命、大限、流年等至少两层结构可对照"
      ],
      "conflictPolicy": "本命为体、运限为用；运限不得反向覆盖本命盘面事实。",
      "riskBoundary": "运限只说明时间层级触发，不承诺事件结果。",
      "sourceRuleIds": [
        "ziwei.fortune_linkage",
        "ziwei.horoscope_cycles"
      ]
    },
    {
      "id": "bazi.depth.pattern.regular_vs_special",
      "system": "bazi",
      "layer": "core",
      "topic": "格局正变",
      "priority": 94,
      "weight": 0.82,
      "evidenceFields": [
        "geju",
        "baziBenchmark.patternRegistry"
      ],
      "conditions": [
        "月令格局已识别",
        "高级格局条件未完全自证时保持候选"
      ],
      "conflictPolicy": "正格、变格、从格、化气和专旺必须按成败条件分层，不互相覆盖。",
      "riskBoundary": "高级格局未具备 golden 时不得输出强断。",
      "sourceRuleIds": [
        "bazi.pattern_by_month_command",
        "bazi.pattern_root_transparency"
      ],
      "patternMatrix": [
        {
          "name": "正格",
          "sourceRuleId": "bazi.pattern_by_month_command",
          "appliesWhen": [
            "月令主气可取格",
            "透干或藏干能支持月令取象",
            "未触发特殊格局完整条件"
          ],
          "breaksWhen": [
            "月令不清或节气边界未验证",
            "合冲刑害破改变取格依据但无证据链",
            "从格、化气、专旺条件已完整成立"
          ],
          "riskBoundary": "正格只作为解释优先级，不替代完整命例判断。"
        },
        {
          "name": "变格",
          "sourceRuleId": "bazi.pattern_root_transparency",
          "appliesWhen": [
            "月令取格后出现透干、通根、合冲导致取象转移",
            "原始正格有明确破格因素"
          ],
          "breaksWhen": [
            "缺少透干/通根证据",
            "只因文案偏好调整格局名称",
            "无法解释破格来源"
          ],
          "riskBoundary": "变格必须保留原始取格和变格证据，不直接覆盖正格。"
        },
        {
          "name": "从格",
          "sourceRuleId": "bazi.pattern_by_month_command",
          "appliesWhen": [
            "日主极弱且自党扶助极少",
            "财官食伤等外部势力显著成势",
            "无有效印比破从"
          ],
          "breaksWhen": [
            "日主有强根或透出生扶",
            "岁运或原局出现印比破从",
            "外部势力不专一"
          ],
          "riskBoundary": "从格未具备完整条件时只能输出 candidate/guarded。"
        },
        {
          "name": "假从",
          "sourceRuleId": "bazi.pattern_root_transparency",
          "appliesWhen": [
            "日主偏弱且外部势力强",
            "仍存在少量自党或反向证据"
          ],
          "breaksWhen": [
            "自党扶助足以转为普通弱格",
            "外部势力不成气候",
            "缺少通根/透干证据"
          ],
          "riskBoundary": "假从必须显式标注反证，不得写成真从。"
        },
        {
          "name": "专旺",
          "sourceRuleId": "bazi.pattern_root_transparency",
          "appliesWhen": [
            "日主强旺且同党成势",
            "月令或通根支持一气专旺",
            "泄耗制化不能破坏主体气势"
          ],
          "breaksWhen": [
            "财官食伤强力制泄",
            "月令不支持专旺",
            "同党数量不足或根气不稳"
          ],
          "riskBoundary": "专旺候选必须等待 golden 反例验证后才能提高置信度。"
        },
        {
          "name": "化气",
          "sourceRuleId": "bazi.ganzhi_priority",
          "appliesWhen": [
            "天干五合成对出现",
            "化神得月令或通根支持",
            "化神透出且无直接阻隔"
          ],
          "breaksWhen": [
            "月令不助化神",
            "化神无根无透",
            "出现冲破、争合或克制阻隔"
          ],
          "riskBoundary": "化气必须依赖合化条件链，不得由合象直接跳到成化。"
        }
      ]
    },
    {
      "id": "bazi.depth.pattern.follow_transform_guard",
      "system": "bazi",
      "layer": "boundary",
      "topic": "从格化气保护",
      "priority": 70,
