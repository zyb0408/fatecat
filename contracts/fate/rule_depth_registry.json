    {
      "id": "bazi.depth.yongshen.tiaohou_priority",
      "system": "bazi",
      "layer": "core",
      "topic": "调候优先级",
      "priority": 91,
      "weight": 0.81,
      "evidenceFields": [
        "climateScores",
