      "evidenceFields": [
        "ziweiInterpretation.surroundedPalaces",
        "ziweiPalaceRelations"
      ],
      "conditions": [
        "命宫或身宫三方四正可取得"
      ],
      "conflictPolicy": "原生 surroundedPalaces 优先；手工对宫/夹宫只作补充结构。",
      "riskBoundary": "只输出宫位关系证据，不代替流派断法。",
      "sourceRuleIds": [
        "ziwei.surrounded_palaces",
