# FateCat 生产配置模板
# 复制到目标平台的 secret/config 系统，不要提交真实值。

# API 服务监听；容器内通常保持 0.0.0.0:8001，由反向代理暴露公网。
FATE_SERVICE_HOST=0.0.0.0
FATE_SERVICE_PORT=8001

# 公网域名 CORS allowlist，必须填写真实 HTTPS origin，禁止使用 *。
FATE_CORS_ALLOW_ORIGINS=https://your-domain.example

# 公共服务防护。
FATE_MAX_REQUEST_BYTES=1048576
FATE_REQUEST_TIMEOUT_SECONDS=30
FATE_RATE_LIMIT_PER_MINUTE=120
FATE_TRUST_PROXY_HEADERS=1
FATE_ENABLE_HSTS=1

# 记录接口。纯公共排盘服务建议关闭，避免在 SQLite 中保存用户输入。
FATE_RECORDS_ENABLED=0
FATE_API_TOKEN=
FATE_API_ADMIN_TOKEN=
FATE_API_USER_TOKENS=

# Telegram Bot 只在启用 Bot 交付时配置。
FATE_BOT_TOKEN=
FATE_ADMIN_USER_IDS=
FATE_BOT_PROXY_URL=
