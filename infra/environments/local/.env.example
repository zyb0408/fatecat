# FateCat 配置模板

# Telegram Bot
FATE_BOT_TOKEN=
FATE_ADMIN_USER_IDS=
FATE_BOT_PROXY_URL=

# API 服务
FATE_SERVICE_HOST=127.0.0.1
FATE_SERVICE_PORT=8001
# 逗号分隔 CORS allowlist；默认空列表，不默认放开公网跨域
FATE_CORS_ALLOW_ORIGINS=
# 记录接口 admin token；FATE_API_TOKEN 保留兼容，FATE_API_ADMIN_TOKEN 是推荐显式名称
FATE_API_TOKEN=
FATE_API_ADMIN_TOKEN=
# 用户级 token，格式：user_id:token,user_id2:token2；用户 token 只能访问自己的记录
FATE_API_USER_TOKENS=
# 是否启用用户记录接口和本地 SQLite 记录库；公网纯排盘服务可设为 0
FATE_RECORDS_ENABLED=1

# 公共服务防护
# 单请求体上限，默认 1MiB
FATE_MAX_REQUEST_BYTES=1048576
# 单请求处理超时，单位秒
FATE_REQUEST_TIMEOUT_SECONDS=30
# 单 IP 每分钟请求数；0 表示关闭，公网生产不建议关闭
FATE_RATE_LIMIT_PER_MINUTE=120
# 只有在可信反向代理后才打开，打开后使用 X-Forwarded-For 做限流键
FATE_TRUST_PROXY_HEADERS=
# 只有 HTTPS 生产域名确认后打开；本地 HTTP 不应打开
FATE_ENABLE_HSTS=
